{
  "name": "graphite-interactive-cli",
  "version": "0.2.0",
  "description": "Interactive menu for the Graphite CLI (gt) — stacks, PRs, and branching without memorizing commands",
  "type": "module",
  "bin": {
    "gtm": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "graphite",
    "gt",
    "cli",
    "interactive",
    "stack",
    "pr",
    "git"
  ],
  "author": "Nicholas McComb",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickmccomb/graphite-interactive-cli.git"
  },
  "bugs": {
    "url": "https://github.com/nickmccomb/graphite-interactive-cli/issues"
  },
  "homepage": "https://github.com/nickmccomb/graphite-interactive-cli#readme",
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "citty": "^0.2.1",
    "consola": "^3.4.0",
    "execa": "^9.5.2",
    "is-interactive": "^2.0.0",
    "picocolors": "^1.1.1",
    "read-package-up": "^11.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.0.8",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  }
}
